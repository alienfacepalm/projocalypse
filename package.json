{
  "name": "projocalypse",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@11.5.0",
  "type": "module",
  "scripts": {
    "dev": "vite --open",
    "build": "tsc -b && vite build",
    "build:cli": "pnpm --filter @projocalypse/plan build && pnpm --filter @projocalypse/core build && pnpm --filter @projocalypse/gap build && pnpm --filter @projocalypse/cli build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run && vitest run --config vitest.packages.config.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:pr": "pnpm test && pnpm build:cli && pnpm build && pnpm lint",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "pm": "node packages/cli/dist/index.js",
    "pm:init": "pnpm pm init",
    "pm:doctor": "pnpm pm doctor",
    "pm:plan": "node packages/cli/dist/index.js plan parse --package projocalypse",
    "pm:gap": "node packages/cli/dist/index.js gap --all",
    "pm:gap:ci": "node packages/cli/dist/index.js gap --package projocalypse --fail-on STATUS_MISMATCH",
    "pm:sync": "node packages/cli/dist/index.js sync --all",
    "pm:status": "node packages/cli/dist/index.js status --all"
  },
  "dependencies": {
    "@projocalypse/core": "workspace:*",
    "@projocalypse/gap": "workspace:*",
    "@projocalypse/plan": "workspace:*",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-alert-dialog": "^1.1.16",
    "@radix-ui/react-checkbox": "^1.3.4",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-dropdown-menu": "^2.1.17",
    "@radix-ui/react-label": "^2.1.9",
    "@radix-ui/react-popover": "^1.1.16",
    "@radix-ui/react-separator": "^1.1.9",
    "@radix-ui/react-slot": "^1.2.5",
    "@radix-ui/react-tooltip": "^1.2.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "dexie": "^4.4.3",
    "dexie-react-hooks": "^4.4.0",
    "lucide-react": "^1.18.0",
    "react": "^19.2.6",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.17.0",
    "tailwind-merge": "^3.6.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.8"
  }
}
